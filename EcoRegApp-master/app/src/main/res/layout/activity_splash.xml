<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_login_gradient">

    <!-- Logo con círculo -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal">
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_splash_circle"/>
        <ImageView
            android:id="@+id/iv_splash_logo"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_gravity="center"
            android:src="@drawable/eco_reg_logo"
            android:scaleType="fitCenter"
            android:contentDescription="Logo"
            android:alpha="0"/>
    </FrameLayout>

    <!-- Nombre app -->
    <TextView
        android:id="@+id/tv_splash_nombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EcoRegApp"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginTop="24dp"
        android:alpha="0"/>

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/tv_splash_subtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestión de Residuos Industriales"
        android:textColor="#BAFFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="6dp"
        android:alpha="0"/>

    <!-- Empresa -->
    <TextView
        android:id="@+id/tv_splash_empresa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ECOLIM S.A.C."
        android:textColor="#A5D6A7"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginTop="4dp"
        android:alpha="0"/>

    <!-- Spacer -->
    <Space android:layout_width="0dp" android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Progreso inferior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="52dp"
        android:paddingStart="48dp"
        android:paddingEnd="48dp">

        <TextView
            android:id="@+id/tv_splash_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Iniciando..."
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginBottom="10dp"
            android:alpha="0"/>

        <ProgressBar
            android:id="@+id/progress_splash"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="100"
            android:progress="0"
            android:progressTint="#A5D6A7"
            android:progressBackgroundTint="#30FFFFFF"
            android:alpha="0"/>
    </LinearLayout>
</LinearLayout>
