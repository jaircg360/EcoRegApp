<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- ══════════════════════════════════════════
         HEADER REDISEÑADO
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_reportes_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="22dp"
        android:paddingBottom="20dp">

        <!-- Fila: ícono + título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊"
                android:textSize="20sp"
                android:layout_marginEnd="10dp"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reportes"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Análisis · ECOLIM S.A.C."
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Separador sutil -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#25FFFFFF"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="10dp"/>

        <!-- Etiqueta período -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERÍODO"
            android:textColor="#80FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <!-- Tabs de período: 4 botones en fila con fondo cápsula -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_container"
            android:padding="4dp">

            <TextView
                android:id="@+id/chip_hoy"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Hoy"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_tab_active"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/chip_semana"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Semana"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:background="@android:color/transparent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/chip_mes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Mes"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:background="@android:color/transparent"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>

            <TextView
                android:id="@+id/chip_todos"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Todo"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:background="@android:color/transparent"
                android:layout_marginStart="2dp"/>
        </LinearLayout>

        <!-- chip_group_periodo invisible — requerido por ReportesFragment -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_periodo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:singleSelection="true">
            <com.google.android.material.chip.Chip android:id="@+id/chip_hoy_real"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="true"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_semana_real"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_mes_real"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_todos_real"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- Progress bar de exportación -->
    <ProgressBar
        android:id="@+id/progress_export"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent"
        android:visibility="gone"/>

    <!-- ══════════════════════════════════════════
         CONTENIDO SCROLLABLE
    ══════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="90dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── TARJETAS DE ESTADÍSTICAS ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Stat: Peso total -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚖️"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:id="@+id/tv_total_kg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/primary"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="kg totales"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat: Registros -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:id="@+id/tv_total_reg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/info"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="registros"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat: Tipos -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🗂️"
                            android:textSize="22sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:id="@+id/tv_total_tipos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/warning"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="tipos"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── GRÁFICO DE DONA ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISTRIBUCIÓN POR TIPO"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Dona + leyenda en horizontal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.ecolim.ecoregapp.ui.views.DonutChartView
                            android:id="@+id/chart_dona"
                            android:layout_width="0dp"
                            android:layout_height="180dp"
                            android:layout_weight="1.1"/>

                        <!-- Leyenda al costado -->
                        <LinearLayout
                            android:id="@+id/layout_leyenda"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.9"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── GRÁFICO DE BARRAS ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KG POR TIPO DE RESIDUO"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <com.ecolim.ecoregapp.ui.views.BarChartView
                    android:id="@+id/chart_barras"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:padding="12dp"/>
            </androidx.cardview.widget.CardView>

            <!-- ── FILTRO POR TIPO ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILTRAR POR TIPO"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_tipo_reporte"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    android:padding="14dp"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="4dp">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tipo_todos"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗂 Todos"
                        android:checked="true"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tipo_plastico"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔵 Plástico"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tipo_organico"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢 Orgánico"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tipo_papel"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟡 Papel"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_tipo_peligroso"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴 Peligroso"/>
                </com.google.android.material.chip.ChipGroup>
            </androidx.cardview.widget.CardView>

            <!-- ── EXPORTAR ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPORTAR DATOS"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Exportar PDF -->
                    <LinearLayout
                        android:id="@+id/btn_exportar_pdf"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_btn_exportar_pdf"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📄"
                            android:textSize="20sp"
                            android:layout_marginEnd="12dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Exportar PDF"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reporte completo con gráficos"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Exportar CSV -->
                    <LinearLayout
                        android:id="@+id/btn_exportar_csv"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_btn_exportar_csv"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊"
                            android:textSize="20sp"
                            android:layout_marginEnd="12dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Exportar CSV"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Datos en hoja de cálculo"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
