<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back_editar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Volver"
            app:tint="@android:color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Editar Registro"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"/>

        <TextView
            android:id="@+id/btn_guardar_editar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARDAR"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>

    <!-- CONTENIDO SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Tipo de residuo -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de residuo"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_tipo_editar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_plastico"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Plástico"
                            android:textColor="@color/primary"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/primary"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_organico"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Orgánico"
                            android:textColor="@color/primary"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/primary"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_papel"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Papel"
                            android:textColor="@color/primary"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/primary"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_metal"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Metal"
                            android:textColor="@color/primary"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/primary"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_peligroso"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peligroso"
                            android:textColor="@color/danger"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/danger"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_vidrio"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vidrio"
                            android:textColor="@color/primary"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/primary"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_e_pendiente"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendiente"
                            android:textColor="@color/text_hint"
                            app:chipBackgroundColor="@color/surface"
                            app:chipStrokeColor="@color/text_hint"
                            app:chipStrokeWidth="1dp"/>

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Datos principales -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Datos del registro"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Peso -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Peso (kg) *"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/et_peso_editar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:hint="Ej: 5.2"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Zona -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zona"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <Spinner
                        android:id="@+id/spinner_zona_editar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Ubicación -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ubicación"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/et_ubicacion_editar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_field"
                        android:inputType="text"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:hint="Ej: Almacén principal"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>

                    <!-- Observaciones -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Observaciones"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <EditText
                        android:id="@+id/et_observaciones_editar"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_input_field"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="8dp"
                        android:hint="Notas adicionales..."
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: EPP (solo visible para peligroso) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_epp_editar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#FFF8E1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Equipos de Protección Personal"
                        android:textColor="#E65100"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <CheckBox
                        android:id="@+id/cb_guantes_editar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guantes de protección"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp"/>

                    <CheckBox
                        android:id="@+id/cb_mascarilla_editar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mascarilla / Respirador"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp"/>

                    <CheckBox
                        android:id="@+id/cb_lentes_editar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lentes de seguridad"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Info: Datos no editables -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="#F5F9F7">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ Información del registro"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Fecha"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_fecha_editar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Operario"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_operario_editar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Zona"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_turno_editar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
