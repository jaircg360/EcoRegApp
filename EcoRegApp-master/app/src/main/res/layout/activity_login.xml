<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- Círculo decorativo superior derecho -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        android:background="@drawable/bg_circle_deco_top"
        android:alpha="0.18"/>

    <!-- Círculo decorativo inferior izquierdo -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-60dp"
        android:layout_marginStart="-60dp"
        android:background="@drawable/bg_circle_deco_bottom"
        android:alpha="0.14"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp">

            <!-- ── ZONA SUPERIOR: logo + título ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="56dp"
                android:layout_marginBottom="36dp">

                <!-- Contenedor logo con sombra suave -->
                <FrameLayout
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginBottom="20dp">
                    <View
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:background="@drawable/bg_logo_glow"
                        android:alpha="0.35"/>
                    <ImageView
                        android:id="@+id/iv_logo"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:src="@drawable/eco_reg_logo"
                        android:scaleType="fitCenter"
                        android:contentDescription="EcoRegApp Logo"/>
                </FrameLayout>

                <!-- Nombre app -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EcoRegApp"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:layout_marginBottom="4dp"/>

                <!-- Línea separadora decorativa -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View android:layout_width="32dp" android:layout_height="1dp"
                        android:background="#60FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  ECOLIM S.A.C.  "
                        android:textColor="#90FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"/>
                    <View android:layout_width="32dp" android:layout_height="1dp"
                        android:background="#60FFFFFF"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestión de Residuos · NTP 900.058"
                    android:textColor="#60FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>
            </LinearLayout>

            <!-- ── CARD PRINCIPAL DE LOGIN ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="24dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Título dentro de la card -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Iniciar sesión"
                        android:textColor="#1B5E20"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingresa tus credenciales para continuar"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp"/>

                    <!-- Separador verde -->
                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="@drawable/bg_divider_green"
                        android:layout_marginBottom="24dp"/>

                    <!-- Campo ID Operario -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID DE OPERARIO"
                        android:textColor="#1B5E20"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_badge"
                        app:startIconTint="#2E7D32"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#2E7D32"
                        app:hintEnabled="false"
                        android:layout_marginBottom="18dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_operario_id"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ej: OP-01, ADMIN"
                            android:textColor="#212121"
                            android:textColorHint="#AAAAAA"
                            android:inputType="textCapCharacters"
                            android:text="OP-42"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Campo Contraseña -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTRASEÑA"
                        android:textColor="#1B5E20"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#2E7D32"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#2E7D32"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#2E7D32"
                        app:hintEnabled="false"
                        android:layout_marginBottom="28dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tu contraseña"
                            android:textColor="#212121"
                            android:textColorHint="#AAAAAA"
                            android:inputType="textPassword"
                            android:text="ecolim2026"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón ingresar -->
                    <Button
                        android:id="@+id/btn_ingresar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="INGRESAR AL SISTEMA"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        app:cornerRadius="14dp"
                        android:backgroundTint="#1B5E20"/>

                    <!-- Progress -->
                    <ProgressBar
                        android:id="@+id/progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:indeterminateTint="#2E7D32"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── BADGE DEMO ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge_demo"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑"
                    android:textSize="13sp"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Demo: OP-01 / OP-42 / OP-10 / ADMIN · ecolim2026"
                    android:textColor="#DDFFFFFF"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>